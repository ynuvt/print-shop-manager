{
  "name": "@printowl/db",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prisma:generate": "prisma generate",
    "users:backup": "node --loader ts-node/esm scripts/backupUserData.ts",
