generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// {
//   userId: string,          // user.uid
//   files: [                 // array of uploaded files
//     {
//       name: string,        // original file name
//       pages: number,       // total pages in file
//       url: string,         // Firebase Storage download URL
//       options: {
//         paperSize: string,       // "A4"
//         colorMode: string,       // "bw" | "color"
//         pageRange: string,       // "all" | "custom"
//         customRange: string,     // e.g. "1-5,8,10-12"
//         customRangeError: string,
//         duplex: string,          // "one" | "both"
//         copies: number,
//       },
//       cost: number,        // cost for this specific file
//     }
//   ],
//   totalCost: number,       // sum of all files cost
//   totalPages: number,      // sum of all files pages
//   estimatedTime: number,   // Math.ceil(totalPages * 0.2) in minutes
//   status: string,          // "processing" | "completed" | "rejected" | "failed"
//   verificationCode: string, // 4-digit code e.g. "4821"
//   createdAt: Timestamp,    // Firebase serverTimestamp()
//   notified: boolean,       // false on creation, true after completion notify
// }

enum PaperSize {
  A4
  A3
  Letter
  Legal
}

enum ColorMode {
  BW
  COLOR
}
enum pageRange {
  ALL
  CUSTOM
}
enum duplex {
  ONE
  BOTH
}

enum orientation {
  PORTRAIT
  LANDSCAPE
}

enum scaleMode {
  FIT
  SHRINK
  NOSCALE
}

enum PrintJobStatus {
  DRAFT // this status will be used for jobs that is created with whatsapp source as we want to create the job in the database as soon as we receive the message from whatsapp so that if the user send one file then another file slowly then we'll keep adding it to his currnet draft job and once he confirms the order then we'll change the status to pending. For web source we can directly set the status to pending when the job is created as we expect all the files to be send in one request and the options will be default.
  Editing // this status will be used when the user is editing the job, either from whatsapp or from web, so that we can show the current status of the job as editing while the user is making changes to it and once he's done with the changes then we can update the status back to pending. This will help us in showing the correct status of the job to the user and also in case of whatsapp source we can show a message like "Your order is being processed, please wait while we update your order with the new file/options" when the user is editing the job.
  PROCESSING //processing will come first in case we later support word to pdf conversion and we want to show the job as processing while the conversion is happening, once the conversion is done then we can update the status to pending which means it's ready for printing. For now we can directly set it to pending when the job is created.
  PENDING 
  COMPLETED
  REJECTED
  FAILED
  CANCELED
}

enum UserEventType {
  ONBOARDING_SKIPPED
}
enum Source {
  WEB
  WHATSAPP
}

enum FileOwnerRole {
  OWNER
  COLLABORATOR
}



model printOption {
  id       String   @id @default(uuid())
  createdAt DateTime @default(now())
  paperSize PaperSize  @default(A4)
  colorMode ColorMode  @default(BW)
  orientation orientation @default(PORTRAIT)
  scaleMode scaleMode @default(FIT)
  pageRange pageRange  @default(ALL)
  customRange String?
  duplex     duplex  @default(ONE)
  copies    Int
  fileId    String   @unique
  file      file     @relation(fields: [fileId], references: [id], onDelete: Cascade, map: "printoption_fileId_fkey")
}

model file {
  id       String   @id @default(uuid())
  name     String
  mimeType String   @default("application/pdf")
  messageId  String?
  createdAt DateTime @default(now())
  pages    Int
  url      String
  fileCost Float    @default(0)
  uploadedByUserId String?
  uploadedByUser   User?        @relation("UserUploadedFiles", fields: [uploadedByUserId], references: [id], map: "file_uploadedByUserId_fkey")
  uploadedByPhoneNumber String?
  uploadedByWhatsAppUser WhatsAppUser? @relation("WhatsAppUserUploadedFiles", fields: [uploadedByPhoneNumber], references: [phoneNumber], map: "file_uploadedByPhoneNumber_fkey")
  uploadedByDisplayName String?
  uploadedByRole FileOwnerRole  @default(OWNER)
  option   printOption?
  printJobId String
  printJob PrintJob    @relation(fields: [printJobId], references: [id], onDelete: Cascade, map: "file_printJobId_fkey")

  @@index([printJobId, uploadedByUserId])
  @@index([printJobId, uploadedByPhoneNumber])
}

model WhatsAppUser {
  phoneNumber        String   @id
  name               String?
  lastFileStartedProcessingAt DateTime?
  lastMessageAt      DateTime?
  userId             String?  @unique
  user               User?    @relation(fields: [userId], references: [id], map: "whatsappuser_userId_fkey")
  printJobs          PrintJob[]
  uploadedFiles      file[]   @relation("WhatsAppUserUploadedFiles")
  loginOtps          WhatsAppLoginOtp[]
}

model WhatsAppLoginOtp {
  id           String   @id @default(uuid())
  code         String   @unique
  phoneNumber  String
  whatsAppUser WhatsAppUser @relation(fields: [phoneNumber], references: [phoneNumber], onDelete: Cascade, map: "whatsapploginotp_phoneNumber_fkey")
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime @default(now())
}
model PrintJob {
  id               String   @id @default(uuid())
  userId           String?
  user             User?     @relation(fields: [userId], references: [id], map: "printjob_userId_fkey")
  owners           PrintJobOwner[]
  files            file[]
  totalCost        Float
  source           Source   @default(WEB)
  userMetadataId   String?
  userMetadata     WhatsAppUser? @relation(fields: [userMetadataId], references: [phoneNumber], map: "printjob_userMetadataId_fkey")
  totalPages       Int
  estimatedTime    Int
  deleted          Boolean  @default(false)
  expired          Boolean  @default(false)
  status           PrintJobStatus @default(PENDING)
  verificationCode Int?           @unique
  oldOtp           Int?
  createdAt        DateTime @default(now())
  notified         Boolean  @default(false)
}

model User {
  id                   String      @id
  onboardingCompleted  Boolean     @default(false)
  printJobs            PrintJob[]
  printJobOwners       PrintJobOwner[]
  uploadedFiles        file[]      @relation("UserUploadedFiles")
  events               UserEvent[]
  whatsAppUser         WhatsAppUser?
  name                  String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model PrintJobOwner {
  userId     String
  printJobId String
  createdAt  DateTime @default(now())
  isDone     Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  printJob   PrintJob @relation(fields: [printJobId], references: [id], onDelete: Cascade)

  @@id([userId, printJobId])
  @@index([printJobId])
}

model UserEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], map: "userevent_userId_fkey")
  type      UserEventType
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

model MobileSyncOtp {
  id          String    @id @default(cuid())
  syncId      String    @unique
  otp         String    @unique
  phoneNumber String?
  userId      String?
  token       String?
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
}
