socket_url=http://localhost:3000
JWT_SECRET=supersecretkey
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/printowl?schema=public"

# Cloudflare R2 (required for backend file upload flow)
R2_ACCOUNT_ID=REDACTED
R2_ACCESS_KEY_ID=REDACTED
R2_SECRET_ACCESS_KEY=REDACTED
R2_BUCKET_NAME=printowl
R2_PUBLIC_BUCKET_URL=https://your-bucket-url.r2.dev

# Optional: max single file upload size in MB (default is 50)
MAX_UPLOAD_MB=50

# Admin login credentials used by /api/v1/auth/admin-login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Cloudflare Turnstile CAPTCHA (for upload CAPTCHA protection)
# Get this from: https://dash.cloudflare.com/
# Go to Turnstile → Create Site → Copy the Secret Key
# IMPORTANT: Keep this secret! Never expose in frontend code
TURNSTILE_SECRET_KEY=REDACTED
