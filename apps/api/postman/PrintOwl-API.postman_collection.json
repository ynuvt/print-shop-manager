            "body": {
              "mode": "raw",
              "raw": "{\n  \"paperSize\": \"A4\",\n  \"colorMode\": \"COLOR\",\n  \"orientation\": \"PORTRAIT\",\n  \"scaleMode\": \"FIT\",\n  \"pageRange\": \"ALL\",\n  \"customRange\": \"\",\n  \"duplex\": \"ONE\",\n  \"copies\": 2\n}"
