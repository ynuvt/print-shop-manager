    {
      "name": "Files",
      "description": "Operations on individual files within a print job.",
      "item": [
        {
          "name": "Add File to Job",
          "description": "Adds a single file to an existing DRAFT job.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
