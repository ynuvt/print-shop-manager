    {
      "name": "Analysis",
      "description": "Analytics and summary reports for administrators.",
      "item": [
        {
          "name": "Summary (overall)",
          "description": "Returns deep business insights including revenue, AOV, conversion funnels (Draft -> Completed), source attribution (Web vs WhatsApp), and WhatsApp performance metrics.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/analysis/summary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "analysis", "summary"]
            }
          }
        },
        {
          "name": "Summary (by date)",
          "description": "Returns deep business insights (revenue, conversion, etc.) filtered by a specific date (YYYY-MM-DD).",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/analysis/summary?date={{analysisDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "analysis", "summary"],
              "query": [{ "key": "date", "value": "{{analysisDate}}" }]
            }
          }
        },
        {
          "name": "Users (overall)",
          "description": "Returns user-centric metrics such as activation rates (users creating jobs), onboarding completion/skip rates, and customer retention (repeat users).",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/analysis/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "analysis", "users"]
            }
          }
        },
        {
          "name": "Users (by date)",
          "description": "Returns user-centric metrics (acquisition, onboarding) filtered by a specific date (YYYY-MM-DD).",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/analysis/users?date={{analysisDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "analysis", "users"],
              "query": [{ "key": "date", "value": "{{analysisDate}}" }]
            }
          }
        },
        {
          "name": "User Activity (by ID)",
          "description": "Returns a detailed summary of a specific user's print jobs, including completion rates and creation timestamps.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/analysis/user-activity/7aa55cf0-af2c-407f-91ca-f49fc0840306",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "analysis", "user-activity", "7aa55cf0-af2c-407f-91ca-f49fc0840306"]
            }
          }
        }
      ]
    },
    {
      "name": "Maintenance",
      "description": "System administration and cleanup tasks.",
      "item": [
        {
          "name": "Expire Old PrintJobs (24h+)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "description": "Expires jobs older than 24 hours. Marks them as expired, frees up their 4-digit verification codes, and deletes their files from R2 storage.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/maintenance/expire-old-printjobs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "maintenance", "expire-old-printjobs"]
            }
          }
        },
        {
          "name": "Cleanup Old PrintJobs (DELETE alias)",
