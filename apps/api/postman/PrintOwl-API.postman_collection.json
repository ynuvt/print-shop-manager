              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/jobs/all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "jobs", "all"]
