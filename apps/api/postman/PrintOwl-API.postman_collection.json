          }
        },
        {
          "name": "Get Job by Verification Code",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/jobs/{{verificationCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "jobs", "{{verificationCode}}"]
            }
          }
        },
        {
          "name": "Delete Job",
          "request": {
            "method": "DELETE",
            "header": [
