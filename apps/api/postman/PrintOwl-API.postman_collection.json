{
  "info": {
    "name": "Zopy API",
    "description": "Comprehensive API collection for the Zopy print platform.\n\nBase URL defaults to http://localhost:4000.\n\n**Quick Start:**\n1. Run 'Register (customer)' to get a customer token.\n2. Run 'Admin Login' to get an admin token.\n3. Use the relevant endpoints with the auto-populated tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "customerToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "adminEmail", "value": "admin@example.com" },
    { "key": "adminPassword", "value": "admin123" },
    { "key": "verificationCode", "value": "" },
    { "key": "jobId", "value": "" },
    { "key": "fileId", "value": "" },
    { "key": "analysisDate", "value": "2026-04-27" },
    { "key": "sampleFilePath", "value": "/absolute/path/to/sample.pdf" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /healthz",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/healthz",
              "host": ["{{baseUrl}}"],
              "path": ["healthz"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Authentication and synchronization endpoints for customers, admins, and WhatsApp users.",
      "item": [
        {
          "name": "Register (customer token)",
          "description": "Generates a unique anonymous customer ID and JWT token for new users. This token is used to identify the user across sessions until they sync with WhatsApp.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set('customerToken', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Admin Login",
          "description": "Authenticates an administrator using email and password. Returns an admin JWT for restricted operations.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set('adminToken', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/admin-login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "admin-login"]
            }
          }
        },
        {
          "name": "WhatsApp Login (OTP)",
          "description": "Syncs a web user session with a WhatsApp account. Requires a 6-digit OTP code sent via WhatsApp.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set('customerToken', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"replace-with-otp-code\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/whatsapp-login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "whatsapp-login"]
            }
          }
        },
        {
          "name": "Mobile Sync — Generate OTP",
          "description": "Generates a unique sync ID and a 6-digit OTP to link a mobile device with the current user account.",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/mobile-sync",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "mobile-sync"]
            }
          }
        },
        {
          "name": "Mobile Sync — Poll Status",
          "description": "Checks if the mobile sync OTP has been successfully verified and returns the user token if linked.",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/mobile-sync/status?syncId=replace-with-syncId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "mobile-sync", "status"],
              "query": [{ "key": "syncId", "value": "replace-with-syncId" }]
            }
          }
        },
        {
          "name": "Open App (deep link redirect)",
          "description": "A redirect page that tries to open the mobile app via deep link, falling back to the website.",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/open-app?syncId=replace-with-syncId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "open-app"],
              "query": [{ "key": "syncId", "value": "replace-with-syncId" }]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "description": "User profile and session management.",
      "item": [
