              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": \"{{jobId}}\",\n  \"files\": [\n    {\n      \"id\": \"replace-with-file-id\",\n      \"options\": {\n        \"paperSize\": \"A4\",\n        \"colorMode\": \"BW\",\n        \"orientation\": \"PORTRAIT\",\n        \"scaleMode\": \"FIT\",\n        \"pageRange\": \"ALL\",\n        \"customRange\": \"\",\n        \"duplex\": \"ONE\",\n        \"copies\": 1\n      }\n    }\n  ]\n}"
