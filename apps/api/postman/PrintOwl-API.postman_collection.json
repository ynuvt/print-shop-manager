            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/onboarding/skipped",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "onboarding", "skipped"]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "description": "Print job management, including creation, status updates, and retrieval.",
      "item": [
        {
          "name": "Presign Uploads",
          "description": "Generates presigned URLs for uploading files directly to Cloudflare R2 storage. Supports PDF, Office docs, and Images.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"files\": [\n    { \"name\": \"sample.pdf\", \"contentType\": \"application/pdf\" }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/jobs/presign-uploads",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "jobs", "presign-uploads"]
            }
          }
        },
        {
          "name": "Create with URLs",
          "description": "Creates a new print job from a list of publicly accessible URLs (usually from R2).",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.verificationCode) {",
                  "  pm.collectionVariables.set('verificationCode', String(data.verificationCode));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"files\": [\n    {\n      \"name\": \"sample.pdf\",\n      \"url\": \"https://example.com/sample.pdf\",\n      \"options\": {\n        \"paperSize\": \"A4\",\n        \"colorMode\": \"BW\",\n        \"orientation\": \"PORTRAIT\",\n        \"scaleMode\": \"FIT\",\n        \"pageRange\": \"ALL\",\n        \"customRange\": \"\",\n        \"duplex\": \"ONE\",\n        \"copies\": 1\n      }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/jobs/create-with-urls",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "jobs", "create-with-urls"]
            }
          }
        },
        {
          "name": "Get Web Draft",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set('jobId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/jobs/web-draft",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "jobs", "web-draft"]
            }
          }
        },
        {
          "name": "Add Files to Web Draft",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"files\": [\n    {\n      \"name\": \"another.pdf\",\n      \"url\": \"https://example.com/another.pdf\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/jobs/web-draft/add-files",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "jobs", "web-draft", "add-files"]
            }
          }
        },
        {
          "name": "Add Files from URLs to Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"files\": [\n    {\n      \"name\": \"extra.pdf\",\n      \"url\": \"https://example.com/extra.pdf\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/jobs/{{jobId}}/add-files-from-urls",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "jobs", "{{jobId}}", "add-files-from-urls"]
            }
          }
        },
        {
          "name": "Get All Jobs (admin)",
          "request": {
            "method": "GET",
