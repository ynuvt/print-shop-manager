{
  "name": "electron-app",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "npm run build:renderer && npm run build:main",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "dist:win:portable": "npm run build && electron-builder --win portable --x64",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "devv": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "dev:main": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5174 dist-electron/main.js && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5174 electron dist-electron/main.js",
    "start": "npm run build && electron dist-electron/main.js",
    "check-types": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "pdf-lib": "^1.17.1",
    "pdf-to-printer": "^5.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@printowl/types": "^1.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.4.0",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.zopy.desktop",
    "productName": "Zopy",
    "artifactName": "Zopy Setup ${version}.${ext}",
    "electronVersion": "37.4.0",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "resources/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/ZopyPrinter",
        "to": "ZopyPrinter",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
