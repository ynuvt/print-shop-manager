# API Configuration
VITE_API_ORIGIN=http://localhost:4000

# Cloudflare Turnstile CAPTCHA
# Get these from: https://dash.cloudflare.com/
# 1. Sign in or create a free Cloudflare account
# 2. Go to Turnstile section in the dashboard
# 3. Click "Create Site"
# 4. Fill in your site details
# 5. Copy the Site Key and Secret Key

# Frontend Site Key (public, safe to expose)
VITE_TURNSTILE_SITE_KEY=0x4AAAAAACuh4ffhEY5SnUoU

# Backend Secret Key (private, KEEP SECRET!)
# Add this to your backend .env file, NOT here
# TURNSTILE_SECRET_KEY=your_secret_key_here
