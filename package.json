{
  "name": "cloud-print-shop-manager",
  "version": "1.0.0",
  "description": "Electron desktop application for managing print shop jobs via Firebase.",
  "main": "public/main.js",
  "scripts": {
    "start": "react-scripts start",
    "electron": "electron .",
    "dev": "concurrently \"cross-env BROWSER=none PORT=3001 npm start\" \"wait-on http://localhost:3001 && electron .\"",
    "dev:test": "concurrently \"cross-env BROWSER=none PORT=3001 npm start\" \"wait-on http://localhost:3001 && electron public/main_test.js\"",
    "build": "react-scripts build",
    "package": "npm run build && electron-builder -w -c.extraMetadata.main=build/main.js"
  },
  "author": "Print Shop Dev",
  "license": "MIT",
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "firebase-admin": "^12.0.0",
    "fs-extra": "^11.2.0",
    "pdf-to-printer": "^5.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "uuid": "^9.0.1",
    "lucide-react": "^0.330.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "tailwindcss": "^3.4.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.cloudprint.manager",
    "productName": "Cloud Print Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "public/main.js",
      "public/preload.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}