# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules
.pnp
.pnp.js

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage

# Turbo
.turbo

# Vercel
.vercel
dist-electron/
# native/ folders (except ZopyPrinter source which we need to track)
# Note: apps/electron/native/ is handled below with fine-grained rules

# Build Outputs
.next/
out/
build
dist


# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.DS_Store
*.pem

# Build artifacts and release files
apps/electron/release/
apps/electron/release.zip
apps/electron/dist-electron/
# Ignore native build artifacts, but allow source + pre-built binary
apps/electron/native/*
!apps/electron/native/ZopyPrinter/
apps/electron/native/ZopyPrinter/*
!apps/electron/native/ZopyPrinter/Program.cs
!apps/electron/native/ZopyPrinter/ZopyPrinter.csproj
!apps/electron/native/ZopyPrinter/VERSION
!apps/electron/native/ZopyPrinter/README.md
!apps/electron/native/ZopyPrinter/PDFiumConfig.cmake
# Ignore resources except ZopyPrinter pre-built binary
apps/electron/resources/*
!apps/electron/resources/ZopyPrinter/
!apps/electron/resources/ZopyPrinter/**
!apps/electron/resources/icon.png
# *.exe is excluded globally but allow the ZopyPrinter ones in resources
*.exe
!apps/electron/resources/ZopyPrinter/*.exe

# Native C# build outputs
apps/electron/native/ZopyPrinter/bin/
apps/electron/native/ZopyPrinter/obj/

# Runtime tracking cache (file-backed cache for webhook performance)
apps/api/data/
